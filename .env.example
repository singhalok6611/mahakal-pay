# ─────────────────────────────────────────────────────────────
# Mahakal Pay - Environment configuration
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development
DB_PATH=./data/mahakal.db

# JWT (use long random strings in production — e.g. `openssl rand -hex 64`)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Legacy alias (still read by older code paths)
JWT_SECRET=change-me-access-secret

# Razorpay (https://dashboard.razorpay.com/app/keys)
# Use test keys (rzp_test_*) during development
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
MIN_TOPUP_AMOUNT=100
MAX_TOPUP_AMOUNT=100000

# Platform fee (auto-deducted to admin wallet on every transaction)
PLATFORM_FEE_PCT=1.0
PLATFORM_ADMIN_ID=1

# Cyrus Recharge API (https://cyrusrecharge.in) — legacy, kept for reference
CYRUS_MODE=mock
CYRUS_API_BASE=
CYRUS_API_MEMBER_ID=
CYRUS_API_PASSWORD=

# ─────────────────────────────────────────────────────────────
# Pay2All — chosen production recharge provider
# Docs: https://documenter.getpostman.com/view/5618532/2sA2xnyVt5
#
# Set all three to go live. If any one is blank, the service falls
# back to MOCK mode and the recharge returns synthetic success
# (so the dashboard, splits, notifications all keep working in dev).
#
#   PAY2ALL_EMAIL          - your Pay2All login email
#   PAY2ALL_PASSWORD       - your Pay2All password
#   PAY2ALL_ACCOUNT_MOBILE - the mobile number registered on the
#                            Pay2All account (Pay2All requires it as
#                            `mobile_number` in the recharge payload,
#                            distinct from the customer's number)
#
# Optional:
#   PAY2ALL_BASE_URL       - default https://erp.pay2all.in
#   PAY2ALL_MODE           - force "mock" to disable live calls even
#                            when creds are set (useful for staging)
# ─────────────────────────────────────────────────────────────
PAY2ALL_EMAIL=
PAY2ALL_PASSWORD=
PAY2ALL_ACCOUNT_MOBILE=
PAY2ALL_BASE_URL=https://erp.pay2all.in
PAY2ALL_MODE=

# ─────────────────────────────────────────────────────────────
# Slice 7: Email (password reset)
# Leave SMTP_* blank for MOCK mode — emails will be printed to the
# server log instead of being sent. The forgot-password flow still works.
#
# To go live with Brevo (https://www.brevo.com  - free 300 emails/day):
#   1. Sign up, verify your sender domain (mahakalpay.in) under
#      "Senders, Domains & Dedicated IPs" — add the SPF + DKIM DNS
#      records they give you.
#   2. SMTP & API -> SMTP -> generate an SMTP key.
#   3. Paste the key into SMTP_PASS below. SMTP_USER is your Brevo login
#      email, SMTP_HOST is smtp-relay.brevo.com, SMTP_PORT is 587.
# ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM="Mahakal Pay <noreply@mahakalpay.in>"
APP_URL=http://localhost:5173
PASSWORD_RESET_TTL_MIN=60
