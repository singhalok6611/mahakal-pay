{
  "version": 2,
  "buildCommand": "cd client && npm install && npx vite build",
  "outputDirectory": "client/dist",
  "installCommand": "cd server && npm install && cd ../client && npm install",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**",
      "excludeFiles": "server/node_modules/better-sqlite3/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
